{
  "manifest_version": 3,
  "name": "MOM Generator - Meeting Recorder",
  "version": "1.0.0",
  "description": "Record Google Meet & Zoom meetings and auto-generate Minutes of Meeting",
  "permissions": [
    "tabCapture",
    "activeTab",
    "storage",
    "offscreen",
    "cookies",
    "notifications"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://*.zoom.us/*",
    "http://localhost:5000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
